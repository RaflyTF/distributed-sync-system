# Node Configuration
NODE_ID=node1
NODE_HOST=0.0.0.0
NODE_PORT=8001

# Cluster Peers (comma-separated)
PEERS=http://node2:8002,http://node3:8003

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Raft Configuration
RAFT_ELECTION_TIMEOUT_MIN=150
RAFT_ELECTION_TIMEOUT_MAX=300
RAFT_HEARTBEAT_INTERVAL=50

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_POLICY=LRU

# Security (Bonus D)
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
ENABLE_TLS=false

# Metrics
METRICS_PORT=9090
ENABLE_METRICS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
